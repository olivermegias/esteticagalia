---
import MapPinIcon from "../icons/MapPinIcon.astro";
import PhoneIcon from "../icons/PhoneIcon.astro";
import ClockIcon from "../icons/ClockIcon.astro";
import { business } from "../../data/business";
---

<section class="location">
  <div class="container">
    <div class="location-content">
      <div class="location-info">
        <h2>Encuéntranos</h2>

        <div class="info-item">
          <MapPinIcon size={24} class="info-icon" />
          <div>
            <strong>Dirección</strong>
            <p>{business.address.street}<br />{business.address.city}, {business.address.postalCode}</p>
          </div>
        </div>

        <div class="info-item">
          <PhoneIcon size={24} class="info-icon" />
          <div>
            <strong>Teléfono</strong>
            <p>
              {business.phones.map((p, i) => (
                <>
                  <a href={`tel:${p.number}`}>{p.display}</a>
                  {i < business.phones.length - 1 && " / "}
                </>
              ))}
            </p>
          </div>
        </div>

        <div class="info-item">
          <ClockIcon size={24} class="info-icon" />
          <div>
            <strong>Horario</strong>
            <p>
              Lunes: 15:00 - 19:00<br />
              Martes a Viernes: 10:00 - 19:00<br />
              Sábados: 10:00 - 14:00
            </p>
          </div>
        </div>
      </div>

      <div class="location-map" data-cookie-map>
        <div class="location-map__placeholder" data-cookie-map-placeholder>
          <p>
            Para mostrar el mapa de Google Maps necesitamos tu consentimiento para cookies de terceros.
            Si las aceptas, podrás ver la ubicación exacta aquí mismo. Si las rechazas, no cargaremos
            contenido de Google y podrás abrir la ruta en un enlace externo.
          </p>
          <a class="location-map__link" href={business.mapDirectionsUrl} target="_blank" rel="noopener noreferrer">
            Abrir en Google Maps
          </a>
        </div>
        <template data-cookie-map-template>
          <iframe
            src={business.mapEmbedUrl}
            width="600"
            height="450"
            style="border:0;"
            allowfullscreen=""
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            title="Ubicación de Estética GaliaBeauty en Granada"
          ></iframe>
        </template>
      </div>
    </div>
  </div>
</section>

<script>
  (function () {
    var mapRoot = document.querySelector("[data-cookie-map]");

    if (!(mapRoot instanceof HTMLElement)) return;

    var mapRootElement = mapRoot;

    var placeholderElement = mapRootElement.querySelector("[data-cookie-map-placeholder]");
    var templateElement = mapRootElement.querySelector("[data-cookie-map-template]");
    var placeholder = placeholderElement instanceof HTMLElement ? placeholderElement : null;
    var template = templateElement instanceof HTMLTemplateElement ? templateElement : null;
    var consentKey = "cookie-consent";
    var mapRendered = false;

    function getConsent() {
      try {
        return localStorage.getItem(consentKey);
      } catch (error) {
        return null;
      }
    }

    function renderMap() {
      if (mapRendered || getConsent() !== "accepted" || !template) return;

      mapRootElement.appendChild(template.content.cloneNode(true));
      mapRendered = true;

      if (placeholder) {
        placeholder.hidden = true;
      }
    }

    function syncMap() {
      if (getConsent() === "accepted") {
        renderMap();
        return;
      }

      if (placeholder) {
        placeholder.hidden = false;
      }
    }

    document.addEventListener("astro:page-load", syncMap);
    window.addEventListener("cookie-consent-change", function () {
      syncMap();
    });

    syncMap();
  })();
</script>

<style>
  .location {
    padding: 4rem 0;
    background: var(--color-bg);
  }

  .location-content {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 3rem;
    align-items: center;
  }

  .location-info h2 {
    color: var(--color-text);
    font-size: 2rem;
    margin-bottom: 2rem;
  }

  .info-item {
    display: flex;
    gap: 1rem;
    margin-bottom: 1.5rem;
    align-items: flex-start;
  }

  .info-item :global(.info-icon) {
    color: var(--color-text);
    flex-shrink: 0;
    margin-top: 0.25rem;
  }

  .info-item strong {
    display: block;
    color: var(--color-text);
    margin-bottom: 0.25rem;
    font-weight: 600;
  }

  .info-item p {
    color: var(--color-text);
    margin: 0;
    line-height: 1.6;
  }

  .info-item a {
    color: var(--color-text);
    text-decoration: underline;
    transition: color var(--transition-base);
  }

  .info-item a:hover {
    color: var(--color-secondary);
    text-decoration: none;
  }

  .location-map {
    height: 400px;
    border-radius: var(--radius-lg);
    overflow: hidden;
    box-shadow: var(--shadow-lg);
    background: linear-gradient(135deg, rgba(201, 168, 124, 0.12), rgba(255, 255, 255, 0.96));
    border: 1px solid var(--color-border-light);
  }

  .location-map__placeholder {
    height: 100%;
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 1rem;
    text-align: center;
  }

  .location-map__placeholder p {
    margin: 0;
    color: 'black';
    line-height: 1.7;
  }

  .location-map__link {
    align-self: center;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 44px;
    padding: 0.75rem 1.25rem;
    border-radius: var(--radius-sm);
    background: var(--color-secondary);
    color: #fff;
    font-weight: 600;
    text-decoration: none;
    transition: transform var(--transition-base), opacity var(--transition-base);
  }

  .location-map__link:hover {
    opacity: 0.92;
    transform: translateY(-1px);
  }

  .location-map iframe {
    width: 100%;
    height: 100%;
  }

  @media (max-width: 768px) {
    .location { padding: 2.5rem 0; }
    .location-info h2 { font-size: 1.5rem; text-align: center; }
    .location-map { height: 280px; border-radius: 12px; }
  }
</style>
