---
const withBase = (path: string) => `${import.meta.env.BASE_URL}${path.replace(/^\//, "")}`;
---
<section class="center-photos">
  <div class="container">
    <h2 class="section-title text-center">Nuestro Centro</h2>
    <div class="photos-grid">
      <div class="photo">
        <img src={withBase("/images/centro1.jpeg")} alt="Centro de estética GaliaBeauty" loading="lazy" />
      </div>
    </div>
  </div>
</section>

<style>
  .center-photos {
    padding: 1rem 0 3rem;
    background: var(--color-bg-soft);
  }
  .section-title {
    margin-bottom: 1.5rem;
  }
  .photos-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
    max-width: 980px;
    margin: 0 auto;
  }
  .photo {
    aspect-ratio: 4 / 3;
    border-radius: 12px;
    overflow: hidden;
    box-shadow: 0 4px 15px rgba(0, 0, 0, 0.1);
  }
  .photo img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: 56% 28%;
    display: block;
    transition: transform 0.3s ease;
  }
  .photo:hover img {
    transform: scale(1.05);
  }
  @media (max-width: 768px) {
    .photos-grid {
      grid-template-columns: 1fr;
    }

    .photo {
      aspect-ratio: 3 / 4;
    }

    .photo img {
      object-position: 56% 24%;
    }
  }
</style>

