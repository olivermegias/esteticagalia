---
import PhoneIcon from "./icons/PhoneIcon.astro";
import MailIcon from "./icons/MailIcon.astro";
import WhatsAppIcon from "./icons/WhatsAppIcon.astro";
import InstagramIcon from "./icons/InstagramIcon.astro";
import { business } from "../data/business";
import { navLinks } from "../data/navigation";
import TiktokIcon from "./icons/TiktokIcon.astro";

const withBase = (path: string) => `${import.meta.env.BASE_URL}${path.replace(/^\//, "")}`;
const currentPath = Astro.url.pathname;
const basePath = import.meta.env.BASE_URL === "/" ? "" : import.meta.env.BASE_URL.replace(/\/$/, "");
const currentPathNoBase = basePath && currentPath.startsWith(basePath)
  ? currentPath.slice(basePath.length) || "/"
  : currentPath;

const isActive = (path: string) => {
  if (path === "/") return currentPathNoBase === "/";
  return currentPathNoBase.startsWith(path);
};
---

<header class="header">
  <div class="header-top">
    <div class="container">
      <div class="contact-info">
        <a href={`tel:${business.phones[0].number}`} class="contact-item">
          <PhoneIcon size={16} />
          <span class="contact-text">{business.phones[0].display}</span>
        </a>
        <a href={`tel:${business.phones[1].number}`} class="contact-item">
          <PhoneIcon size={16} />
          <span class="contact-text">{business.phones[1].display}</span>
        </a>
        <a href={`mailto:${business.email}`} class="contact-item contact-email">
          <MailIcon size={16} />
          <span class="contact-text">{business.email}</span>
        </a>
      </div>
      <div class="social-links">
        <a href={business.social.whatsapp} target="_blank" rel="noopener" aria-label="WhatsApp" class="social-link whatsapp">
          <WhatsAppIcon size={18} />
        </a>
        <a href={business.social.instagram} target="_blank" rel="noopener" aria-label="Instagram" class="social-link instagram">
          <InstagramIcon size={18} />
        </a>
        <a href={business.social.tiktok} target="_blank" rel="noopener" aria-label="TikTok" class="social-link tiktok">
          <TiktokIcon size={18} />
        </a>
      </div>
    </div>
  </div>

  <div class="header-main">
    <div class="container">
      <a href={withBase("/")} class="logo">
        <img src={withBase("/images/logo_new.webp")} alt={business.name} class="logo-img"/>
      </a>

      <div class="mobile-actions">
        <a href={business.social.whatsapp} target="_blank" rel="noopener" aria-label="WhatsApp" class="social-link whatsapp">
          <WhatsAppIcon size={16} />
        </a>
        <a href={business.social.instagram} target="_blank" rel="noopener" aria-label="Instagram" class="social-link instagram">
          <InstagramIcon size={16} />
        </a>
        <a href={business.social.tiktok} target="_blank" rel="noopener" aria-label="TikTok" class="social-link tiktok">
          <TiktokIcon size={16} />
        </a>
        <button class="mobile-menu-toggle" aria-label="Abrir menú" id="mobileMenuToggle">
          <span></span>
          <span></span>
          <span></span>
        </button>
      </div>

      <nav class="nav" id="mainNav">
        <div class="nav-links">
          {navLinks.map((link) => (
            <a
              href={withBase(link.href)}
              class:list={[
                "nav-link",
                { active: isActive(link.href) && (link.href !== "/" || currentPathNoBase === "/") },
              ]}
            >
              {link.label}
            </a>
          ))}
        </div>
        <a
          href={business.social.whatsapp}
          target="_blank"
          rel="noopener"
          class="btn-cta"
        >
          Reserva online
        </a>
      </nav>
    </div>
  </div>
</header>

<script is:inline>
  let headerController = null;

  const cleanupHeader = () => {
    headerController?.abort();
    headerController = null;
  };

  function initHeader() {
    cleanupHeader();
    headerController = new AbortController();
    const { signal } = headerController;

    const header = document.querySelector(".header");
    const mobileMenuToggle = document.getElementById("mobileMenuToggle");
    const mainNav = document.getElementById("mainNav");
    let ticking = false;

    function handleScroll() {
      if (!ticking) {
        window.requestAnimationFrame(() => {
          const scrollY = window.scrollY;
          header?.classList.toggle("scrolled", scrollY > 20);
          ticking = false;
        });
        ticking = true;
      }
    }

    window.addEventListener("scroll", handleScroll, { passive: true, signal });

    mobileMenuToggle?.addEventListener("click", () => {
      mobileMenuToggle.classList.toggle("active");
      mainNav?.classList.toggle("active");
      document.body.classList.toggle("menu-open");
    }, { signal });

    const navLinks = document.querySelectorAll(".nav-link, .btn-cta");
    navLinks.forEach((link) => {
      link.addEventListener("click", () => {
        mobileMenuToggle?.classList.remove("active");
        mainNav?.classList.remove("active");
        document.body.classList.remove("menu-open");
      }, { signal });
    });

    document.addEventListener("click", (e) => {
      const target = e.target;
      if (!(target instanceof HTMLElement)) return;
      if (!target.closest(".header-main") && mainNav?.classList.contains("active")) {
        mobileMenuToggle?.classList.remove("active");
        mainNav?.classList.remove("active");
        document.body.classList.remove("menu-open");
      }
    }, { signal });
  }

  document.addEventListener("astro:page-load", initHeader);
  document.addEventListener("astro:before-swap", cleanupHeader);
</script>

<style is:global>
  /* Sin padding extra ya que el header es estático */
</style>

<style>
  .header {
    position: relative;
    top: 0;
    left: 0;
    width: 100%;
    z-index: 1000;
    background-color: var(--color-brand);
  }

  .header.scrolled {
    box-shadow: var(--shadow-md);
  }

  /* BARRA SUPERIOR - La animamos con max-height para evitar saltos */
  .header-top {
    color: white;
    padding: 8px 0;
    font-size: 0.85rem;
    max-height: 100px; 
    opacity: 1;
    transition: max-height 0.3s ease, opacity 0.2s ease, padding 0.3s ease;
    overflow: hidden;
  }

  .header.scrolled .header-top {
    max-height: 0;
    padding-top: 0;
    padding-bottom: 0;
    opacity: 0;
    pointer-events: none;
  }

  .header-top .container {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 1rem;
  }

  /* CONTENIDO PRINCIPAL */
  .header-main {
    padding: 1rem 0;
    transition: padding 0.3s ease;
  }

  .header.scrolled .header-main {
    padding: 0.5rem 0;
  }

  .header-main .container {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1.5rem;
    position: relative;
    z-index: 100;
  }

  /* RESTO DE ESTILOS (IGUALES) */
  .contact-info { display: flex; gap: 1.5rem; flex-wrap: wrap; }
  .contact-item { display: flex; align-items: center; gap: 0.5rem; color: var(--color-text); text-decoration: none; transition: color var(--transition-base); }
  .contact-item:hover { color: var(--color-accent); }
  .social-links { display: flex; gap: 1rem; }
  .social-links a { display: flex; align-items: center; justify-content: center; width: 32px; height: 32px; border-radius: 50%; background: white; color: var(--color-secondary); transition: all var(--transition-base); }
  .social-links a:hover { background: var(--color-primary); color: white; transform: translateY(-2px); }

  .mobile-actions { display: none; align-items: center; gap: 0.5rem; }
  .mobile-actions .social-link { display: flex; align-items: center; justify-content: center; width: 28px; height: 28px; border-radius: 50%; background: white; color: var(--color-secondary); transition: all var(--transition-base); }
  .mobile-actions .social-link:hover { background: var(--color-primary); color: white; transform: translateY(-1px); }

  .logo { padding: 0.5rem 1.25rem; background: white; border-radius: var(--radius-full); border: none; box-shadow: var(--shadow-sm); transition: all var(--transition-base); }
  .logo:hover { transform: translateY(-2px); box-shadow: var(--shadow-md); }
  .logo-img { height: 50px; width: auto; display: block; transition: height 0.3s ease; }
  .header.scrolled .logo-img { height: 40px; }

  .nav { display: flex; align-items: center; gap: 2rem; flex: 1; }
  .nav-links { display: flex; align-items: center; gap: 2rem; margin: 0 auto; }
  .nav-link { color: var(--color-text); text-decoration: none; font-weight: 500; transition: color var(--transition-base); position: relative; }
  .nav-link::after { content: ""; position: absolute; bottom: -5px; left: 0; width: 0; height: 2px; background: var(--color-accent); transition: width var(--transition-base); }
  .nav-link:hover::after, .nav-link.active::after { width: 100%; }

  .btn-cta { padding: 0.7rem 1.6rem; background: var(--color-accent); color: var(--color-secondary); text-decoration: none; border-radius: var(--radius-full); font-weight: 600; transition: all var(--transition-base); white-space: nowrap; display: inline-flex; align-items: center; gap: 0.5rem; border: 1px solid rgba(255, 255, 255, 0.5); box-shadow: var(--shadow-sm); }
  .btn-cta:hover { color: var(--color-secondary); background: #fff; transform: translateY(-2px); box-shadow: var(--shadow-md); }

  .mobile-menu-toggle { display: none; flex-direction: column; gap: 5px; background: white; border: none; cursor: pointer; padding: 0.6rem; border-radius: var(--radius-sm); z-index: 100; }
  .mobile-menu-toggle span { width: 22px; height: 2px; background: var(--color-secondary); transition: all var(--transition-base); border-radius: 2px; }
  .mobile-menu-toggle.active span:nth-child(1) { transform: rotate(45deg) translate(5px, 5px); }
  .mobile-menu-toggle.active span:nth-child(2) { opacity: 0; }
  .mobile-menu-toggle.active span:nth-child(3) { transform: rotate(-45deg) translate(5px, -5px); }

  @media (max-width: 768px) {
    .header-top { display: none; }
    .header-main { padding: 0.75rem 0; }
    .mobile-actions { display: flex; }
    .mobile-menu-toggle { display: flex; }
    .nav { position: fixed; top: 0; left: 0; right: 0; bottom: 0; flex-direction: column; background: white; padding: 5rem 2rem 2rem; gap: 1rem; box-shadow: var(--shadow-lg); transform: translateX(100%); opacity: 0; pointer-events: none; transition: all 0.3s ease; z-index: 50; overflow-y: auto; }
    .nav.active { transform: translateX(0); opacity: 1; pointer-events: all; }
    .nav-links { width: 100%; flex-direction: column; gap: 0; margin: 0; }
    .nav-link { color: var(--color-secondary); font-size: 1.1rem; padding: 1rem 0; border-bottom: 1px solid #f0f0f0; width: 100%; text-align: center; }
    .nav-link::after { display: none; }
    .nav-link.active { color: var(--color-primary); font-weight: 600; }
    .btn-cta { width: 100%; text-align: center; justify-content: center; margin-top: 1.5rem; padding: 1rem 1.5rem; font-size: 1rem; }
    .logo { padding: 0.35rem 0.75rem; }
    .logo-img { height: 38px; }
    .header.scrolled .logo-img { height: 38px; }
  }
</style>