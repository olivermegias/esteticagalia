---
const withBase = (path: string) => `${import.meta.env.BASE_URL}${path.replace(/^\//, "")}`;
---

<div id="cookie-banner" class="cookie-banner" aria-live="polite" role="region" aria-label="Aviso de cookies">
  <div class="cookie-banner__inner">
    <p class="cookie-banner__text">
      Este sitio web utiliza cookies de terceros de Google Maps para mostrar nuestra ubicación.
      Si las aceptas, el mapa se cargará y Google podrá instalar cookies asociadas a ese servicio.
      Si las rechazas, no se cargará el mapa y podrás seguir usando el resto de la web.
      <a href={withBase("/politica-cookies")} class="cookie-banner__link">Más información</a>
    </p>
    <div class="cookie-banner__actions">
      <button id="cookie-reject-btn" class="cookie-banner__btn cookie-banner__btn--secondary" type="button">
        Rechazar
      </button>
      <button id="cookie-accept-btn" class="cookie-banner__btn" type="button">
        Aceptar
      </button>
    </div>
  </div>
</div>

<script>
  // Declaramos una función limpia que se ejecutará en cada navegación
  function initCookieBanner() {
    const banner = document.getElementById("cookie-banner");
    const btn = document.getElementById("cookie-accept-btn");
    const rejectBtn = document.getElementById("cookie-reject-btn");
    const consentKey = "cookie-consent";

    if (!(banner instanceof HTMLElement)) return;

    function getStoredConsent() {
      try {
        return localStorage.getItem(consentKey);
      } catch (error) {
        return null;
      }
    }

    function saveConsent(value: "accepted" | "rejected") {
      try {
        localStorage.setItem(consentKey, value);
      } catch (error) {
        // Fallback si el almacenamiento local está bloqueado
      }
      window.dispatchEvent(new CustomEvent("cookie-consent-change", { detail: { consent: value } }));
      console.log("Consentimiento de cookies guardado:", value);
    }

    function hideBanner() {
      if (!banner) return;
      banner.style.display = "none";
      banner.setAttribute("aria-hidden", "true");
    }

    function showBanner() {
      if (!banner) return;
      banner.style.display = "block";
      banner.removeAttribute("aria-hidden");
    }

    // Evaluación en cada carga/cambio de página
    const currentConsent = getStoredConsent();
    if (currentConsent === "accepted" || currentConsent === "rejected") {
      hideBanner();
      return; // El consentimiento ya existe, no asignamos listeners
    }

    // Si no hay respuesta previa, nos aseguramos de mostrar el banner
    showBanner();

    // Como los elementos se destruyen y recrean en cada página, asignamos listeners siempre de cero
    if (btn) {
      btn.addEventListener("click", function () {
        saveConsent("accepted");
        hideBanner();
      });
    }

    if (rejectBtn) {
      rejectBtn.addEventListener("click", function () {
        saveConsent("rejected");
        hideBanner();
      });
    }
  }

  // Se ejecuta la primera vez Y cada vez que cambies de ruta con ClientRouter
  document.addEventListener("astro:page-load", initCookieBanner);
</script>

<style>
  .cookie-banner {
    display: none; /* Oculto por defecto; JS lo muestra si no hay consentimiento */
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    z-index: 9999;
    background: var(--color-secondary, #2d2d2d);
    color: #fff;
    box-shadow: 0 -2px 12px rgba(0, 0, 0, 0.18);
  }

  .cookie-banner__inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 1rem 1.5rem;
    display: flex;
    align-items: center;
    gap: 1.5rem;
    flex-wrap: wrap;
  }

  .cookie-banner__text {
    flex: 1;
    margin: 0;
    font-size: 0.9rem;
    line-height: 1.6;
    color: rgba(255, 255, 255, 0.9);
  }

  .cookie-banner__actions {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .cookie-banner__link {
    color: var(--color-primary, #c9a87c);
    text-decoration: underline;
    font-weight: 500;
    white-space: nowrap;
    margin-left: 0.25rem;
  }

  .cookie-banner__link:hover {
    color: #fff;
  }

  .cookie-banner__btn {
    flex-shrink: 0;
    background: var(--color-primary, #c9a87c);
    color: #fff;
    border: none;
    border-radius: var(--radius-sm, 0.375rem);
    padding: 0.5rem 1.5rem;
    font-size: 0.9rem;
    font-weight: 600;
    cursor: pointer;
    transition: opacity 0.2s ease;
  }

  .cookie-banner__btn:hover {
    opacity: 0.85;
  }

  .cookie-banner__btn--secondary {
    background: transparent;
    border: 1px solid rgba(255, 255, 255, 0.45);
    color: #fff;
  }

  .cookie-banner__btn--secondary:hover {
    opacity: 1;
    background: rgba(255, 255, 255, 0.08);
  }

  @media (max-width: 540px) {
    .cookie-banner__inner {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.75rem;
    }

    .cookie-banner__btn {
      align-self: stretch;
      text-align: center;
    }

    .cookie-banner__actions {
      width: 100%;
    }
  }
</style>
