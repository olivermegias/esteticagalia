---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getCollection, render } from "astro:content";
import PageHero from "../components/sections/PageHero.astro";
import CtaBanner from "../components/sections/CtaBanner.astro";
import { getBeautySalonSchema, getFAQSchema } from "../data/schema";

const allFaqs = await getCollection("faq");

const faqsByCategory = allFaqs.reduce(
  (acc, faq) => {
    const cat = faq.data.categoria;
    if (!acc[cat]) acc[cat] = [];
    acc[cat].push(faq);
    return acc;
  },
  {} as Record<string, typeof allFaqs>,
);

// Ordenar dentro de cada categoría
Object.values(faqsByCategory).forEach((faqs) =>
  faqs.sort((a, b) => a.data.orden - b.data.orden),
);

const categoryOrder = ["general", "tratamientos", "citas", "pagos"];
const categoryLabels: Record<string, string> = {
  general: "Información General",
  tratamientos: "Sobre los Tratamientos",
  citas: "Citas y Reservas",
  pagos: "Pagos y Bonos Regalo",
};

const categoryIcons: Record<string, string> = {
  general: "M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z",
  tratamientos: "M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z",
  citas: "M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z",
  pagos: "M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z",
};

const schema = getBeautySalonSchema();

// Construir FAQPage schema con datos reales de las FAQ
const faqSchemaData = getFAQSchema(
  allFaqs
    .sort((a, b) => a.data.orden - b.data.orden)
    .map((faq) => ({
      pregunta: faq.data.pregunta,
      respuesta: (faq.body ?? "").replace(/\n+/g, " ").trim(),
    })),
);

// Pre-render all FAQ content components
type RenderedFaq = {
  pregunta: string;
  Content: any;
};
const renderedByCategory: Record<string, RenderedFaq[]> = {};
for (const cat of categoryOrder) {
  if (!faqsByCategory[cat]) continue;
  renderedByCategory[cat] = [];
  for (const faq of faqsByCategory[cat]) {
    const { Content } = await render(faq);
    renderedByCategory[cat].push({
      pregunta: faq.data.pregunta,
      Content,
    });
  }
}
---

<BaseLayout
  title="Preguntas Frecuentes sobre Tratamientos Estéticos en Granada | GaliaBeauty"
  description="Resolvemos tus dudas sobre tratamientos estéticos, citas, preparación y cuidados posteriores. Asesoramiento personalizado en nuestro centro de estética de Granada."
  schema={schema}
>
  <Fragment slot="head">
    <script is:inline type="application/ld+json" set:html={JSON.stringify(faqSchemaData)} />
  </Fragment>
  <PageHero
    title="Asesoramiento"
    subtitle="Resolvemos tus dudas más frecuentes para que te sientas segura y bien informada"
  />

  <section class="faq-section">
    <div class="container">

      <!-- Índice rápido -->
      <nav class="faq-index">
        {categoryOrder.map((cat) => faqsByCategory[cat] && (
          <a href={`#${cat}`} class="faq-index-item">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d={categoryIcons[cat]} />
            </svg>
            {categoryLabels[cat]}
          </a>
        ))}
      </nav>

      <!-- Categorías de FAQ -->
      {categoryOrder.map((cat) => renderedByCategory[cat] && (
        <div class="faq-category" id={cat}>
          <div class="faq-category-header">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d={categoryIcons[cat]} />
            </svg>
            <h2>{categoryLabels[cat]}</h2>
          </div>
          <div class="faq-list">
            {renderedByCategory[cat].map(({ pregunta, Content }) => (
              <details class="faq-item">
                <summary class="faq-question">
                  <span>{pregunta}</span>
                  <svg class="faq-chevron" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                    <polyline points="6 9 12 15 18 9" />
                  </svg>
                </summary>
                <div class="faq-answer">
                  <Content />
                </div>
              </details>
            ))}
          </div>
        </div>
      ))}

    </div>
  </section>

  <CtaBanner
    title="¿No encuentras tu respuesta?"
    text="Contacta con nosotras y resolveremos todas tus dudas personalmente"
  />
</BaseLayout>

<script is:inline>
  let faqIndexController = null;

  const cleanupFaqIndex = () => {
    faqIndexController?.abort();
    faqIndexController = null;
  };

  const initFaqIndex = () => {
    cleanupFaqIndex();
    faqIndexController = new AbortController();
    const { signal } = faqIndexController;

    document.querySelectorAll('.faq-index-item').forEach((link) => {
      link.addEventListener('click', (e) => {
        e.preventDefault();
        const href = link.getAttribute('href');
        if (!href) return;
        const target = document.querySelector(href);
        if (target) {
          target.scrollIntoView({ behavior: 'smooth', block: 'start' });
        }
      }, { signal });
    });
  };

  document.addEventListener('astro:page-load', initFaqIndex);
  document.addEventListener('astro:before-swap', cleanupFaqIndex);
</script>

<style>
  /* ══════════════════════════════════════
     FAQ SECTION
  ══════════════════════════════════════ */
  .faq-section {
    padding: 4rem 0;
    background: var(--color-bg-soft);
  }

  /* ── Índice rápido ── */
  .faq-index {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    justify-content: center;
    margin-bottom: 3.5rem;
  }

  .faq-index-item {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.65rem 1.25rem;
    background: white;
    color: var(--color-secondary);
    text-decoration: none;
    border: 1.5px solid var(--color-border-light);
    border-radius: 999px;
    font-size: 0.9rem;
    font-weight: 600;
    transition: all 0.25s ease;
    box-shadow: var(--shadow-sm);
  }

  .faq-index-item:hover {
    border-color: var(--color-primary);
    color: var(--color-primary);
    transform: translateY(-2px);
    box-shadow: var(--shadow-md);
  }

  .faq-index-item svg {
    opacity: 0.6;
    transition: opacity 0.25s;
  }

  .faq-index-item:hover svg {
    opacity: 1;
    color: var(--color-primary);
  }

  /* ── Categoría ── */
  .faq-category {
    margin-bottom: 3rem;
    scroll-margin-top: 2rem;
  }

  .faq-category-header {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 1.5rem;
    padding-bottom: 1rem;
    border-bottom: 2px solid var(--color-primary);
  }

  .faq-category-header svg {
    color: var(--color-primary);
    flex-shrink: 0;
  }

  .faq-category-header h2 {
    font-size: 1.5rem;
    color: var(--color-secondary);
    font-weight: 700;
    margin: 0;
  }

  /* ── Accordion items ── */
  .faq-list {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .faq-item {
    background: white;
    border-radius: var(--radius-md);
    border: 1px solid var(--color-border-light);
    overflow: hidden;
    transition: all 0.25s ease;
  }

  .faq-item:hover {
    border-color: rgba(139, 148, 116, 0.3);
    box-shadow: var(--shadow-sm);
  }

  .faq-item[open] {
    border-color: var(--color-primary);
    box-shadow: 0 4px 16px rgba(139, 148, 116, 0.12);
  }

  .faq-question {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
    padding: 1.25rem 1.5rem;
    cursor: pointer;
    list-style: none;
    font-weight: 600;
    font-size: 1rem;
    color: var(--color-secondary);
    transition: all 0.2s ease;
    user-select: none;
  }

  .faq-question::-webkit-details-marker {
    display: none;
  }

  .faq-question::marker {
    display: none;
    content: "";
  }

  .faq-question:hover {
    color: var(--color-primary);
  }

  .faq-question span {
    flex: 1;
    line-height: 1.45;
  }

  .faq-chevron {
    flex-shrink: 0;
    transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    color: var(--color-muted);
  }

  .faq-item[open] .faq-chevron {
    transform: rotate(180deg);
    color: var(--color-primary);
  }

  /* ── Answer ── */
  .faq-answer {
    padding: 0 1.5rem 1.5rem;
    color: var(--color-muted);
    font-size: 0.975rem;
    line-height: 1.85;
    animation: fadeIn 0.3s ease-out;
  }

  .faq-answer :global(p) {
    margin: 0;
  }

  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(-8px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  /* ══════════════════════════════════════
     RESPONSIVE
  ══════════════════════════════════════ */
  @media (max-width: 768px) {
    .faq-section { padding: 2rem 0; }

    .faq-index {
      gap: 0.5rem;
      margin-bottom: 2.5rem;
    }

    .faq-index-item {
      padding: 0.5rem 1rem;
      font-size: 0.82rem;
    }

    .faq-category-header h2 {
      font-size: 1.25rem;
    }

    .faq-question {
      padding: 1rem 1.25rem;
      font-size: 0.95rem;
    }

    .faq-answer {
      padding: 0 1.25rem 1.25rem;
      font-size: 0.9rem;
    }
  }

  @media (max-width: 480px) {
    .faq-index-item {
      font-size: 0.78rem;
      padding: 0.45rem 0.85rem;
    }

    .faq-index-item svg {
      width: 14px;
      height: 14px;
    }
  }
</style>
