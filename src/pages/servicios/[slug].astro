  }

  .gallery-main:hover .gallery-nav { opacity: 1; }
  .gallery-nav:hover { background: white; transform: translateY(-50%) scale(1.1); box-shadow: 0 8px 20px rgba(0, 0, 0, 0.2); }
  .gallery-nav-prev { left: 1rem; }
  .gallery-nav-next { right: 1rem; }

  .gallery-thumbnails {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(80px, 1fr));
    gap: 0.5rem;
    padding: 1rem;
    background: #f9fafb;
  }

  .thumbnail {
    aspect-ratio: 1;
    border: 2px solid transparent;
    border-radius: 12px;
    overflow: hidden;
    cursor: pointer;
    transition: all 0.3s cubic-bezier(0.68, -0.55, 0.265, 1.55);
