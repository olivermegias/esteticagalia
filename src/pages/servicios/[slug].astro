      justify-content: center;
    }
  }

  @media (max-width: 768px) {
    .servicio-detail { padding: 2rem 0 3rem; }
    .servicio-header h1 { font-size: 1.75rem; }
    .servicio-meta { gap: 0.5rem; }
    .meta-pill { font-size: 0.78rem; padding: 0.35rem 0.7rem; }
