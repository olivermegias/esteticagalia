---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection, render } from "astro:content";
import Gallery from "../../components/islands/Gallery";
import Breadcrumb from "../../components/ui/Breadcrumb.astro";
import PhoneIcon from "../../components/icons/PhoneIcon.astro";
import WhatsAppIcon from "../../components/icons/WhatsAppIcon.astro";
import ClockIcon from "../../components/icons/ClockIcon.astro";
import { business } from "../../data/business";
import { getServiceSchema } from "../../data/schema";

const withBase = (path?: string) => {
  if (!path) return "";
  if (/^(https?:|\/\/|data:|mailto:|tel:)/.test(path)) return path;
  return `${import.meta.env.BASE_URL}${path.replace(/^\//, "")}`;
};

export async function getStaticPaths() {
  const servicios = await getCollection("servicios");
  return servicios.map((servicio) => ({
    params: { slug: servicio.id.replace(/\.md$/, "") },
    props: { servicio },
  }));
}

const { servicio } = Astro.props;
const { Content } = await render(servicio);

const todosServicios = await getCollection("servicios");
const serviciosRelacionados = todosServicios
  .filter(
    (s) =>
      s.data.categoria === servicio.data.categoria &&
      s.id !== servicio.id,
  )
  .slice(0, 3);

const imagenes = servicio.data?.imagen
  ? Array.isArray(servicio.data.imagen)
    ? servicio.data.imagen.map((img) => withBase(img))
    : [withBase(servicio.data.imagen)]
  : [];

const schema = getServiceSchema(servicio.data);
---

<BaseLayout
  title={`${servicio.data.title} - EstÃ©tica GaliaBeauty`}
  description={servicio.data.descripcion}
  image={imagenes[0]}
  schema={schema}
>
  <Breadcrumb
    items={[
      { label: "Inicio", href: "/" },
      { label: "Servicios", href: "/servicios" },
      { label: servicio.data.title },
    ]}
  />

  <section class="servicio-detail">
    <div class="container-wide">
      <div class="servicio-layout">

        <!-- Columna Izquierda: Contenido -->
        <div class="servicio-main">

          <!-- Encabezado: tÃ­tulo + pills precio/duraciÃ³n -->
          <div class="servicio-header">
            <h1>{servicio.data.title}</h1>
            <div class="servicio-meta">
              {servicio.data.duracion && (
                <span class="meta-pill">
                  <ClockIcon size={15} />
                  {servicio.data.duracion}
                </span>
              )}
              {servicio.data.precio && (
                <span class="meta-pill">
                  {servicio.data.precio}
                </span>
              )}
              <span class="meta-pill">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <rect x="3" y="8" width="18" height="13" rx="2"></rect>
                  <path d="M12 8V21"></path>
                  <path d="M3 12h18"></path>
                  <path d="M12 8c-2-3-6-3-6 0s4 3 6 0"></path>
                  <path d="M12 8c2-3 6-3 6 0s-4 3-6 0"></path>
                </svg>
                Bono regalo
              </span>
            </div>
          </div>

          <!-- Contenido Markdown -->
          <article class="servicio-content prose">
            <Content />
          </article>

          <!-- CTA Reserva (en columna izquierda) -->
          <div class="cta-inline">
            <div class="cta-inline-content">
              <div class="cta-inline-text">
                <h3>¿Te interesa este tratamiento?</h3>
                <p>Reserva tu cita o consúltanos sin compromiso</p>
              </div>
              <div class="cta-inline-buttons">
                <a href={`tel:${business.mainPhone}`} class="btn btn-primary">
                  <PhoneIcon size={18} />
                  Llamar
                </a>
                <a href={business.social.whatsapp} class="btn btn-outline" target="_blank" rel="noopener">
                  <WhatsAppIcon size={18} />
                  WhatsApp
                </a>
              </div>
            </div>
          </div>

        </div>

        <!-- Columna Derecha: GalerÃ­a -->
        <aside class="servicio-sidebar">
          <Gallery client:load imagenes={imagenes} title={servicio.data.title} />

          <div class="sidebar-back">
            <a href={withBase("/servicios")} class="link-servicios">← Ver todos los servicios</a>
          </div>
        </aside>
      </div>
    </div>
  </section>

  {serviciosRelacionados.length > 0 && (
    <section class="related-services">
      <div class="container">
        <h2 class="section-title">Tratamientos Relacionados</h2>
        <div class="related-grid">
          {serviciosRelacionados.map((s) => (
            <article class="related-card">
              <a href={withBase(`/servicios/${s.id.replace(/\.md$/, "")}`)} class="related-link">
                <div
                  class="related-image"
                  style={
                    s.data.imagen
                      ? `background-image: url(${withBase(Array.isArray(s.data.imagen) ? s.data.imagen[0] : s.data.imagen)}); background-size: cover; background-position: center;`
                      : "background: var(--color-cream);"
                  }
                >
                  {!s.data.imagen && (
                    <svg class="related-icon" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                      <circle cx="12" cy="12" r="10" />
                      <circle cx="12" cy="12" r="6" />
                    </svg>
                  )}
                </div>
                <div class="related-content">
                  <h3>{s.data.title}</h3>
                  <p>{s.data.descripcion}</p>
                  {s.data.precio && <span class="related-precio">{s.data.precio}</span>}
                </div>
              </a>
            </article>
          ))}
        </div>
      </div>
    </section>
  )}
</BaseLayout>

<style>
  /* ══════════════════════════════════════
