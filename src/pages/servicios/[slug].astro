  }

  /* ══════════════════════════════════════
     SIDEBAR (sin cambios de fondo)
  ══════════════════════════════════════ */
  .servicio-sidebar {
    position: sticky;
    top: 2rem;
  }

  .sidebar-back {
    margin-top: 1.25rem;
    text-align: center;
  }

