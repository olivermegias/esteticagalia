  }
</style>

<style is:global>
  /* ================================
     GALLERY STYLES (sin cambios)
     ================================ */

  .gallery-container {
    background: white;
    border-radius: 16px;
    overflow: hidden;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
    margin-bottom: 2rem;
  }

  .gallery-main {
    position: relative;
    aspect-ratio: 3/4;
    overflow: hidden;
    background: #f9fafb;
  }

  .gallery-main-wrapper {
    width: 100%;
    height: 100%;
    border: none;
    padding: 0;
    cursor: zoom-in;
    position: relative;
    display: block;
    background: none;
  }

