    white-space: nowrap;
  }

  /* Estilos **locales** para los botones dentro del CTA de este servicio
     â€” solo aplican aquÃ­ para no tocar estilos globales */
  .cta-inline .btn {
    padding: 0.75rem 1.25rem;
    border-radius: 999px;
    font-size: 0.95rem;
  }

  /* BotÃ³n principal sobre fondo oscuro: versiÃ³n invertida solo aquÃ­ */
