---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getBeautySalonSchema } from "../data/schema";
import About from "../components/sections/About.astro";
import CenterPhotos from "../components/sections/CenterPhotos.astro";
import LocationMap from "../components/sections/LocationMap.astro";
import { business } from "../data/business";

const schema = getBeautySalonSchema();
const withBase = (path: string) => `${import.meta.env.BASE_URL}${path.replace(/^\//, "")}`;
---

<BaseLayout
  title="Centro de Estética Avanzada en Granada | GaliaBeauty"
  description="Centro de estética avanzada en Granada especializado en tratamientos faciales, corporales, depilación láser y diseño de mirada. Centro oficial OVACO."
  schema={schema}
>
  <Fragment slot="head">
    <link
      rel="preload"
      as="image"
      href={withBase("/images/fondo.webp")}
      fetchpriority="high"
    />
  </Fragment>

  <!-- Hero Section -->
  <section class="hero" style={`--hero-bg: url('${withBase("/images/fondo.webp")}')`}>
    <div class="container">
      <div class="hero-grid">
        <div class="hero-media">
        </div>
        <div class="hero-content">
          <span class="hero-tagline">Centro de Estética Avanzada en Granada</span>
          <h1 class="hero-title">
            Realza tu belleza natural con calma y elegancia
          </h1>
          <p class="hero-quote">
            Cuidamos de tu piel, atendemos sus necesidades y personalizamos los
            tratamientos para conseguir los mejores resultados
          </p>
          <div class="hero-buttons">
            <a href={`tel:${business.mainPhone}`} class="btn btn-primary">Llámanos</a>
            <a href={withBase("/servicios")} class="btn btn-secondary">Explorar Servicios</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <About />
  <CenterPhotos />
  <LocationMap />
</BaseLayout>

<style>
  /* Hero Section – home */
  .hero {
    --hero-bg: none;
    position: relative;
    min-height: 80vh;
    display: flex;
    align-items: center;
    background: var(--hero-bg) center 45% / cover no-repeat, var(--color-cream);
    overflow: hidden;
    padding: 3.5rem 0 4.5rem;
  }

  .hero-grid {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: minmax(0, 0.95fr) minmax(0, 1.05fr);
    align-items: center;
    gap: clamp(2rem, 5vw, 4rem);
  }

  .hero-media {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .hero-media::before {
    content: "";
    position: absolute;
    width: 75%;
    height: 85%;
    top: -10%;
    left: -8%;
    background: rgba(91, 109, 91, 0.12);
    border-radius: 40% 60% 60% 40% / 45% 55% 45% 55%;
    z-index: 0;
  }

  .hero-media-frame {
    position: relative;
    z-index: 1;
    background: transparent;
    padding: 0;
    border-radius: 0;
    box-shadow: none;
  }

  .hero-media-frame img {
    width: min(420px, 80vw);
    height: auto;
    aspect-ratio: 4 / 5;
    object-fit: cover;
    border-radius: 20px;
    display: block;
  }

  .hero-content {
    position: relative;
    z-index: 1;
    max-width: 560px;
    justify-self: end;
    text-align: right;
  }

  .hero-tagline {
    display: inline-flex;
    align-items: center;
    text-transform: uppercase;
    letter-spacing: 0.28em;
    font-size: 0.75rem;
    color: var(--color-brand);
    margin-bottom: 1.25rem;
    font-weight: 700;
    padding: 0.35rem 0.85rem;
    border-radius: var(--radius-full);
    border: 1px solid rgba(91, 109, 91, 0.25);
    background: rgba(255, 255, 255, 0.7);
  }

  .hero-title {
    font-family: var(--font-display);
    font-size: clamp(2.4rem, 5vw, 3.6rem);
    line-height: 1.1;
    margin-bottom: 1rem;
    font-weight: 600;
    color: var(--color-secondary);
  }

  .hero-quote {
    font-size: 1.1rem;
    line-height: 1.7;
    margin-bottom: 2rem;
    max-width: 520px;
    color: var(--color-brand);
  }

  .hero-buttons {
    display: flex;
    gap: 1.25rem;
    justify-content: flex-end;
  }

  @media (max-width: 900px) {
    .hero { min-height: 70svh; }
    .hero-grid { grid-template-columns: 1fr; text-align: center; }
    .hero-media { order: 2; }
    .hero-content { margin: 0 auto; }
    .hero-quote { margin-left: auto; margin-right: auto; }
    .hero-buttons { justify-content: center; flex-wrap: wrap; }
  }

  @media (max-width: 768px) {
    .hero {
      background-position: center 35%;
    }

    .hero::after {
      content: "";
      position: absolute;
      inset: 0;
      background: rgba(243, 227, 210, 0.35);
      z-index: 0;
    }

    .hero-media,
    .hero-media::before {
      display: none;
    }

    .hero-content {
      justify-self: center;
      text-align: center;
      max-width: 92%;
      padding: 1.25rem 1.1rem;
      background: rgba(235, 229, 220, 0.82);
      border-radius: 20px;
      box-shadow: 0 16px 36px rgba(0, 0, 0, 0.12);
    }

    .hero-tagline {
      background: rgba(255, 255, 255, 0.85);
      border-color: rgba(91, 109, 91, 0.2);
    }

    .hero-title {
      font-size: 1.9rem;
      text-wrap: balance;
    }

    .hero-quote {
      color: var(--color-secondary);
    }

    .hero-buttons {
      justify-content: center;
    }
  }

  @media (max-width: 600px) {
    .hero { min-height: 62svh; padding: 2.5rem 0 3.5rem; }
    .hero-tagline { letter-spacing: 0.2em; font-size: 0.7rem; }
    .hero-title { font-size: 1.9rem; }
    .hero-quote { font-size: 1rem; }
    .hero-buttons { flex-direction: column; width: 100%; }
    .hero-buttons .btn { width: 100%; justify-content: center; text-align: center; }
  }
</style>
